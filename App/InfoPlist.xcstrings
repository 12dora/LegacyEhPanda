    "NSPhotoLibraryAddUsageDescription": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We need this permission to save images to your photo library."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "We need this permission to save images to your photo library."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画像をライブラリに保存するにはこの権限が必要です"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미지를 사진 라이브러리에 저정하고 싶으면 이 권한을 허용해주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "需要此权限以保存图像到相册"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "我們需要您提供照片權限來保存圖片到照片"
          }
