    "accessibility.partial": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Retry download. %lld of %lld pages are already available."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Download erneut versuchen. %lld von %lld Seiten sind bereits verfügbar."
