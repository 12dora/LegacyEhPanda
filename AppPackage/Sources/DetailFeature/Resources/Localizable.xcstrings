        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ダウンロードを再試行。すでに %lld / %lld ページが利用可能です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드 다시 시도. 이미 %lld / %lld 페이지를 사용할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重新下载，已有 %lld / %lld 页可用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "重新下載，已有 %lld / %lld 頁可用。"
          }
        }
      }
