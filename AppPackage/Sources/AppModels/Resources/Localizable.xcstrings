    "app_error.quota_exceeded_description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Image quota exceeded.\nPlease wait and try again later."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bildkontingent überschritten.\nBitte warte einen Moment und versuche es dann erneut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "画像の帯域割り当てを使い切りました。\nしばらく待ってからもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이미지 할당량을 모두 사용했습니다.\n잠시 후 다시 시도해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "图片流量额度已用尽。\n请稍后再试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "圖片流量額度已用盡。\n請稍後再試。"
          }
        }
      }
    },
