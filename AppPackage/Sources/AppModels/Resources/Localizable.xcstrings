          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마우스를 올릴 때"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "鼠标悬停时"
